    },
    "Alif Ba Ta Tha": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Әлиф Ба Та Са"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Алиф Ба Та Са"
          }
        }
      }
    },
    "All lessons return to their initial state and review history is cleared.": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Барлық сабақтар бастапқы күйіне оралады, қайталау тарихы өшіріледі."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все уроки вернутся в исходное состояние, история повторений будет очищена."
          }
        }
      }
    },
    "Alphabet": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Әліпби"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Алфавит"
          }
        }
      }
    },
    "Alphabet Song": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Әліпби әні"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Песня об алфавите"
          }
        }
      }
    },
    "Alphabet without revision lessons — the quickest route through the 28 letters": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қайталау сабақтарынсыз әліпби — 28 әріптен өтудің ең жылдам жолы"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Алфавит без уроков повторения — самый быстрый путь через 28 букв"
          }
        }
      }
    },
