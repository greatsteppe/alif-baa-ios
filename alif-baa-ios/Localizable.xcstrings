    "Learn to read and write the Arabic alphabet, from zero. Fully offline — no account, no ads, no analytics.": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Араб әліпбиін нөлден оқып, жазуды үйреніңіз. Толығымен офлайн — аккаунтсыз, жарнамасыз, аналитикасыз."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Учитесь читать и писать арабский алфавит с нуля. Полностью офлайн — без аккаунта, рекламы и аналитики."
          }
        }
      }
    },
    "Learning to read Arabic": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Арабша оқуды үйрену"
          }
