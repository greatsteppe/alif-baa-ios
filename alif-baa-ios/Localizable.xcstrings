{
  "sourceLanguage": "en",
  "strings": {
    "%lld of %lld lessons completed": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld/%2$lld сабақ аяқталды"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пройдено уроков: %1$lld из %2$lld"
          }
        }
      }
    },
    "A beginner": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жаңадан бастаушы"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начинающий"
          }
        }
      }
    },
    "A few minutes with the Arabic letters keeps them fresh.": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Араб әріптерімен бірнеше минут — олар есте жақсы сақталады."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Несколько минут с арабскими буквами — и они останутся в памяти."
          }
        }
      }
    },
    "A new item is available in the Content tab": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "«Мазмұн» қойындысында жаңа материал пайда болды"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Во вкладке «Материалы» появился новый элемент"
          }
        }
      }
    },
    "About Alif Baa": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Alif Baa туралы"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Об Alif Baa"
          }
        }
      }
    },
    "Al-Ikhlas (Sincerity)": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Әл-Ихлас (Ықылас)"
