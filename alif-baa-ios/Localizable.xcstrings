      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Мен қайталадым"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я повторил(а)"
          }
        }
      }
    },
    "Includes revision lessons that re-test earlier letter groups via SRS before advancing": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Алға жылжымас бұрын өткен әріп топтарын қайта тексеретін қайталау сабақтарын қамтиды"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включает уроки повторения, которые перепроверяют пройденные группы букв перед продолжением"
          }
        }
      }
    },
    "Jeem Ha Kho": {
      "localizations": {
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жим Ха Хо"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Джим Ха Хо"
          }
